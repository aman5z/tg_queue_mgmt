# Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs that have admin access
# Leave empty to give ALL users admin access (not recommended for production)
ADMIN_IDS=123456789,987654321

# Public base URL of this server (used for QR code generation and customer links)
BASE_URL=http://localhost:8000

# Port the web server listens on
PORT=8000

# Path to the SQLite database file (default: queue.db in working directory)
# DB_PATH=queue.db
